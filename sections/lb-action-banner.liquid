<div class="lb-collection-action-badge-section">
{% if section.settings.link-active == true %}
<a href="{{ section.settings.link-url }}">
{% endif %}
  <img src="{{ section.settings.collection-action-badge | img_url: '900x' }}" class="lb-collection-action-badge">
{% if section.settings.link-active == true %}
</a>
{% endif %}
</div>
  
<style>

  .lb-collection-action-badge-section {
    padding: 0px!important;
    background: {{ section.settings.backgroundcolor }}!important;
  }

  .lb-collection-action-badge {
    max-width: {{ section.settings.max-width }}px!important;
    border-radius: {{ section.settings.borderradius }}px!important;
    display: block!important;
    width: 100%!important;
    margin: auto!important;
  }
  
</style>


{% schema %}
{
  "name": "lb action badge",
  "settings": [
    {
      "type": "color",
      "id": "backgroundcolor",
      "label": {
        "en": "Hintergrundfarbe",
        "de": "Hintergrundfarbe"
      },
      "default": "#f2f2f2"
    },
    {
      "type": "image_picker",
      "id": "collection-action-badge",
      "label": "Bannerbild"
    },
    {
      "type": "checkbox",
      "id": "link-active",
      "label": "Badge verlinken",
      "default": false
    },
    {
      "type": "url",
      "id": "link-url",
      "label": "Badge URL"
    },
    {
      "type": "range",
      "id": "borderradius",
      "label": {
        "en": "Badge Abrundung",
        "de": "Badge Abrundung"
      },
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "max-width",
      "label": {
        "en": "Badge Maximale Breite",
        "de": "Badge Maximale Breite"
      },
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 400
    }
  ],
  "presets": [
    {
      "category": "HTML",
      "name": "lb action badge",
      "settings": {}
    }
  ]
}
{% endschema %}









