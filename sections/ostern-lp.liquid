        <div class="lb-campaign-collection-filter-item lb-campaign-collection-filter-item-{{ block.id }}"><div>{{ block.settings.rabatttext }}</div></div>
        <script>
          $(document).ready(function() {
            $('.lb-campaign-collection-filter-item-{{ block.id }}').click(function() {
              
              // Alle Elemente mit der Klasse 'lb-campaign-collection-filter-item' zurücksetzen
              $('.lb-campaign-collection-filter-item').removeClass('lb-campaign-collection-filter-item-active');
              
              // Aktuelles Element hervorheben
              $(this).toggleClass('lb-campaign-collection-filter-item-active');
              
              // Alle anderen Elemente mit der Klasse 'lb-campaign-collection-section-holder' zurücksetzen
              $('.lb-campaign-collection-section-holder').removeClass('lb-campaign-collection-section-holder-active');
              
              // Aktuellen Inhalt hervorheben
              $('.lb-campaign-collection-section-holder-{{ block.id }}').toggleClass('lb-campaign-collection-section-holder-active');
            });
          });
        </script>
                 {% endif %}
      {% endfor %}
    {% endif %}

