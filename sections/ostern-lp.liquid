  </div>

  {% for block in section.blocks %}
              {% if block.type == 'categories' %}
    {% if forloop.first %}
      <script>
        $(document).ready(function r() {
          $('.lb-campaign-collection-filter-item-{{ block.id }}').addClass('lb-campaign-collection-filter-item-active');
          $('.lb-campaign-collection-section-holder-{{ block.id }}').addClass('lb-campaign-collection-section-holder-active');   
