<style>

  {% assign primaryfont = section.settings.primaryfont %}
  {% assign secondaryfont = section.settings.secondaryfont %}
  {% assign bannerfont = section.settings.bannerfont %}
  {{ section.settings.primaryfont | font_face }}
  {{ section.settings.secondaryfont | font_face }}
  {{ section.settings.bannerfont | font_face }}

  {% if section.settings.customfont != blank %}
  @font-face {
    font-family: "Customfont";
    src: url("{{ section.settings.customfont }}") format("woff");
  }
  {% endif %}


  
.banneranimation-section {
  background-color: {{ section.settings.bannerbg }};
  color: {{ section.settings.bannercolor }};
  {% if section.settings.bannerbgimage != blank %}
  background-image: url({{ section.settings.bannerbgimage | img_url: '1200x' }});
  {% endif %}
  background-repeat: repeat-x !important;
  background-size: 100% 100% !important;
  padding-top: 18px !important;
  padding-bottom: 18px !important;
  overflow-x: clip !important;
} 

.banneranimation { 	
    font-size:25px;
    margin:0;
    white-space:nowrap;
    width:auto;
    perspective:900px;
    display: -webkit-box;
    display: -webkit-flex;
    display: -ms-flexbox;
    display: flex;
    -webkit-box-pack: start;
    -webkit-justify-content: flex-start;
    -ms-flex-pack: start;
    justify-content: flex-start;
    -webkit-box-align: center;
    -webkit-align-items: center;
    -ms-flex-align: center;
    align-items: center;
    animation: ss-scroller-left 18s linear infinite;
    color: {{ section.settings.bannerfontcolor }};
}
    


@media only screen and (max-width: 600px) {

.banneranimation { 	
    animation: ss-scroller-left 10s linear infinite;
}

}

@keyframes banneranimation {
  0% { transform: translateX(0%); }
  100% { transform: translateX(-100%); }
}

  
  @keyframes ss-scroller-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }


.banneranimation span { 	
  margin-right: 18px;
  line-height: 17px;
  font-size: 17px;
  {% if section.settings.customfont == blank %}
  font-family: {{ section.settings.bannerfont.family }}, {{ bannerfont.fallback_families }} !important;
  {% else %}
  font-family: 'Customfont'!important;
  {% endif %}
}

</style>
















