<div class="lb-collection-header-section">
  <div class="lb-collection-header-section-content">
<h1>{{ collection.title }}</h1>
<p>{{ collection.description }}</p>
  </div>
</div>
<style>
.lb-collection-header-section {
  padding: 52px 18px;
  position: relative;
  background: black;
}
.lb-collection-header-section::after {
  content: " ";
  background: url("{{ collection.image | img_url: '1200x' }}") no-repeat center center;
  background-size: cover;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.3; /* 0.5% Opazität */
  z-index: 99;
}
.lb-collection-header-section-content {
  position: relative;
  z-index: 105;
}
.lb-collection-header-section h1 {
  font-family: BebasNeue-Regular;
  font-size: 24px;
  line-height: 30px;
  text-align: left;
  color: white;
  margin: 0px 0px 5px 0px;
}
.lb-collection-header-section p {
  font-size: 16px;
  line-height: 22px;
  text-align: left;
  color: white;
  margin: 0px 0px 5px 0px;
}
</style>
{% schema %}
{
  "name": "lb collection header",
  "settings": [
    {
      "type": "liquid",
      "id": "customhtml",
      "label": "Badge URL"
    }
  ],
  "presets": [
    {
      "category": "HTML",
      "name": "lb collection header",
      "settings": {}
    }
  ]
}
{% endschema %}









