{%comment %}
{% assign current_date_time = 'now' | date: "%Y.%m.%d-%H:%M:%S" %}
{% assign set_full_time = section.settings.plannable-date-year-start | append: '.' | append: section.settings.plannable-date-month-start | append: '.' | append: section.settings.plannable-date-day-start | append: '-' | append: section.settings.plannable-date-time-start %}
{% assign endDate = section.settings.plannable-date-year | append: '.' | append: section.settings.plannable-date-month | append: '.' | append: section.settings.plannable-date-day | append: '-' | append: section.settings.plannable-date-time %}

{% comment %} 
{% if current_date_time >= set_full_time and current_date_time <= endDate %}
{% endcomment %}
<!-- current_date_time >= set_full_time or -->
{% if current_date_time >= set_full_time or customer.email contains '@lionsbranding.com' or customer.email contains '@stoertebekker.com' or customer.email contains 'helpingbrands.de' %}

<script>
  // Gib das gewünschte Enddatum ein (Jahr, Monat, Tag, Stunde, Minute, Sekunde)
  const endDate = new Date("{{ section.settings.plannable-date-year }}-{{ section.settings.plannable-date-month }}-{{ section.settings.plannable-date-day }}T{{ section.settings.plannable-date-time }}").getTime();

  const countdown = setInterval(function () {
    const currentDate = new Date().getTime();
    const timeLeft = endDate - currentDate;

    if (timeLeft <= 0) {
      clearInterval(countdown);
      document.getElementById("countdown").innerHTML = "Countdown abgelaufen!";
    } else {
      const days = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
      const hours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);

      document.getElementById("days").textContent = String(days).padStart(2, '0');
      document.getElementById("hours").textContent = String(hours).padStart(2, '0');
      document.getElementById("minutes").textContent = String(minutes).padStart(2, '0');
      document.getElementById("seconds").textContent = String(seconds).padStart(2, '0');

      // Überprüfe, ob es keine Tage mehr gibt und füge die Klasse "hiddendiv" hinzu
      if (days <= 0) {
        document.getElementById("day-item").classList.add("hiddendiv");
      }
      if (hours <= 0) {
        document.getElementById("hours-item").classList.add("hiddendiv");
      }
      if (minutes <= 0) {
        document.getElementById("minutes-item").classList.add("hiddendiv");
      }
    
    }
  }, 1000);
</script>
{% if section.settings.fixed-countdownbar == 'design2' %}
<div class="lb-header-countdown-spacer"></div>
{% endif %}
<a {% if section.settings.lb-countdown-linked == true %}href="{{ section.settings.lb-countdown-link-url }}"{% endif %} class="lb-header-countdown-section">
  <div class="lb-header-countdown-text">
    {{ section.settings.lb-countdown-text }}
    {% if section.settings.cta == true %}<div class="lb-header-countdown-button">{{ section.settings.lb-countdown-button-text }}</div>{% endif %}
  </div>
  <div id="lb-header-countdown" class="lb-header-countdown-holder-inline">
    <div class="lb-header-countdown-holder-item" id="day-item">
      <span id="days" class="lb-header-countdown-holder-item-number">00</span><span class="lb-header-countdown-holder-item-text">Tage</span>
    </div>:
    <div class="lb-header-countdown-holder-item" id="hour-item">
      <span id="hours" class="lb-header-countdown-holder-item-number">00</span><span class="lb-header-countdown-holder-item-text">Stunden</span>
    </div>:
    <div class="lb-header-countdown-holder-item" id="minute-item">
      <span id="minutes" class="lb-header-countdown-holder-item-number">00</span><span class="lb-header-countdown-holder-item-text">Minuten</span> 
    </div>:
    <div class="lb-header-countdown-holder-item">
      <span id="seconds" class="lb-header-countdown-holder-item-number">00</span><span class="lb-header-countdown-holder-item-text">Sekunden</span>
    </div>
  </div>
</a>
{% endif %}

