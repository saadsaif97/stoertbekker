<style>
{% assign primary-font = section.settings.lb-primary-font %}
{{ section.settings.primary-font | font_face }}
{% if section.settings.lb-custom-font != blank %}
@font-face {
font-family: "Customfont";
src: url("{{ section.settings.lb-custom-font }}") format("woff2"),
     url("{{ section.settings.lb-custom-font }}") format("woff");
}
{% endif %}
.lb-header-countdown-spacer {
  height: {{ section.settings.countdownbar-height }}px;
  display: block!important;
}
.lb-header-countdown-section {
  overflow: hidden;
  display: inline-flex;
  padding: 0px 9px;

/*
  background-color: #0b150a;
  background: linear-gradient(to right, #0b150a 0%, #545524 100%);
*/

  background: {{ section.settings.lb-countdown-background-color }};

  width: 100%;
  justify-content: center;
  align-items: center;
  text-decoration: none;
  color: {{ section.settings.lb-countdown-text-color }};
  {% if section.settings.fixed-countdownbar == 'design1' or section.settings.fixed-countdownbar == 'design2' %}
  position: fixed;
  {% endif %}
  height: {{ section.settings.countdownbar-height }}px;
  top: 0px;
  width: 100%;
  z-index: 9991;
  {% if section.settings.lb-custom-font == blank %}
  font-family: {{ section.settings.lb-primary-font.family }}, {{ lb-primary-font.fallback_families }} !important;
  {% else %}
  font-family: 'Customfont'!important;
  {% endif %}
}
.lb-header-countdown-text {
  font-size: 16px;
  line-height: 16px;
  color: {{ section.settings.lb-countdown-text-color }};
  margin-bottom: -2px;
}
.lb-header-countdown-holder-inline {
  display: inline-flex;
  font-weight: bold;
  justify-content: center;
  margin: 0px 0px 0px 4px;
}
.lb-header-countdown-holder-item {
  display: inline-block;
  background: {{ section.settings.lb-countdown-time-background-color }};
  padding: 7px 11px 7px 11px;
  border-radius: 3px;
  position: relative;
  margin: 0px 2px 0px 2px;
}
.lb-header-countdown-holder-item-number {
  font-size: 16px;
  line-height: 16px;
  margin: 0px;
  color: {{ section.settings.lb-countdown-time-text-color }}!important;
  position: relative;
  top: -4px;
}
.lb-header-countdown-holder-item-text {
  font-size: 10px;
  line-height: 10px;
  letter-spacing: 0px;
  margin: 0px;
  position: absolute;
  bottom: 3px;
  width: 100%;
  text-align: center;
  color: {{ section.settings.lb-countdown-time-text-color }}!important;
  opacity: 0.8;
  z-index: 9;
  font-weight: normal!important;
  left: 0px;
}
.lb-header-countdown-button {
  padding: 3px 9px;
  border-radius: 6px;
  background: {{ section.settings.lb-countdown-button-background-color }};
  color: {{ section.settings.lb-countdown-button-text-color }};
  font-size: 14px;
  line-height: 14px;
  font-weight: bold;
  display: inline-block;
  margin: 0px 0px 0px 4px;
  position: relative;
  top: -2px;
}
@media screen and (max-width: 600px) {
.lb-header-countdown-holder-item {
  padding: 2px 9px 5px 9px;
}  
.lb-header-countdown-text {
  font-size: 18px;
  line-height: 18px;
  text-align: center;
  width: 50%;
}
.lb-header-countdown-holder-item-number {
  font-size: 14px;
  line-height: 14px;
  top: -2px;
}
.lb-header-countdown-holder-item-text {
  font-size: 7px;
  line-height: 7px;
}
.lb-header-countdown-button {
  font-size: 12px;
  line-height: 12px;
}
}
</style>

