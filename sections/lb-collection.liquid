        <a href="{{ variant.url }}" class="lb-campaign-collection-item {% if product.tags contains 'abtestonlysets' %}lb-set-hide{% endif %}">
          <div class="lb-campaign-collection-item-image">
            <div class="lb-campaign-collection-item-badges">
              {% if product.metafields.custom.custom_tag != blank %}<div>{{ product.metafields.custom.custom_tag }}</div>{% endif %}
            </div>
              {% if product.compare_at_price > product.price %}
                <div class="lb-campaign-collection-item-salebadge">-{{ discount_percent | round }}%</div>
              {% endif %}

        

<div class="lb-item-img-holder">


  {% if product.selected_or_first_available_variant.featured_image == blank %}
  <img class="lb-item-img" id="{{ img_id }}" src="{{ product.featured_image | img_url: '600x' }}" data-src="{{ img_url }}" alt="" loading="lazy">
  {%else%}
<img class="lb-item-img" id="{{ img_id }}" src="{{ variant.featured_image | img_url: '600x' }}" data-src="{{ img_url }}" alt="" loading="lazy">
  {%endif%}         

  
   {% if product.title contains 'Geschenkgutschein' or product.title contains 'Hoodie' or product.title contains 'T-Shirt' %}
     <img class="pdp-item-video" id="{{ img_id }}" src="{{ product.featured_image | img_url: '400x' }}" data-src="{{ img_url }}" alt="" loading="lazy">
  {% else %}
  

<img src="{{  product.images[3] | img_url: '600x' }}" loading="lazy" class="pdp-item-video">
  {% endif %}
  
</div>



<style>
  
  .lb-item-img-holder {
	display: block;
	overflow: hidden;
	position: relative;
  }

  
  
  .lb-item-img-holder:hover .pdp-item-video {
	opacity: 1;
  }

  .lb-item-img {  
width: 100%;
  }

   .lb-item-img-holder:hover .lb-item-img {
opacity: 0!important;
  }


  @media only screen and (max-width: 600px) {
  .lb-item-img-holder:hover .pdp-item-video {
	opacity: 0;
  }
   .lb-item-img-holder:hover .lb-item-img {
opacity: 1!important;
  }
}
  
  
    .pdp-item-video {
	opacity: 0;
	transition: all 0.3s;
	top: 0px;
		width: 100%;
	display: block;
	position: absolute;
	left: 0px;
  }
	

  
  @media only screen and (max-width: 600px) {
  
  .pdp-item-video {

	display: none!important;
  }
	
  }
  
</style>
  



