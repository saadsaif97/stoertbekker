{% comment %}


{% if canonical_url contains 'gutscheine' %}

<div class="collection-filter-section">
  <!-- Sort Dropdown -->
  <div class="sort-dropdown">
    <label for="SortBy">Sortierung:</label>
    <form id="SortForm" method="get" action="{{ collection.url }}">
      <select id="SortBy" name="sort_by">
        <option value="relevance" {% if collection.sort_by == 'relevance' %}selected{% endif %}>Standard</option>
        <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Bestseller</option>
        <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Preis aufsteigend</option>
        <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Preis absteigend</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Neueste</option>
        <option value="created-ascending" {% if collection.sort_by == 'created-ascending' %}selected{% endif %}>Älteste</option>
      </select>
    </form>
  </div>

  <!-- Product Grid -->
  <div id="ProductGrid" class="product-grid">
    {% if collection.products_count > 0 %}
      <ul class="product-list">
        {% for product in collection.products %}
          <li class="product-item">
            <a href="{{ product.url }}">
              {{ product.featured_image | image_url: width: 400 | image_tag: alt: product.title }}
              <h3>{{ product.title }}</h3>
              <p>{{ product.price | money }}</p>
            </a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>Keine Produkte gefunden.</p>
    {% endif %}
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const sortForm = document.getElementById("SortForm");
  const sortSelect = document.getElementById("SortBy");
  const productGrid = document.getElementById("ProductGrid");

  sortSelect.addEventListener("change", function () {
    const formData = new FormData(sortForm);
    const params = new URLSearchParams(formData).toString();

    fetch(`${sortForm.action}?section_id={{ section.id }}&${params}`, {
      headers: { "X-Requested-With": "XMLHttpRequest" }
    })
    .then(response => response.text())
    .then(data => {
      const parser = new DOMParser();
      const html = parser.parseFromString(data, "text/html");
      const updatedGrid = html.getElementById("ProductGrid");
      if (updatedGrid) productGrid.innerHTML = updatedGrid.innerHTML;
    });
  });
});
</script>


{% endif %}


{% endcomment %}