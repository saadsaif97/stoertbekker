          const scrollBy = $currArrow.hasClass('lb-product-m-slider__arrowleft') ? -1 : 1;
          document.querySelector('.js-scrollWidth').scrollBy(scrollBy * innerWidth, 0);
      });
      $('.lb-product-m-slider__dot').on('click', function (e) {
          const requestIndex = $('.lb-product-m-slider__dot').index(e.target);
          document.querySelector('.js-scrollWidth').scrollTo(requestIndex * innerWidth, 0);
      });
      
      $('.gf_swatch').on('click',function(){
          const selectedVariant = $('[data-current-variant]').length && $('[data-current-variant]').attr('data-current-variant');
      
          if(!selectedVariant) {
              return;
          }
      
          $('.js-mSliderItem').each(function(index,item){
              const $item = $(item);
              const assignedVariants = $item.length && $item.attr('data-variants');
              $item.css('order','');
              if(!assignedVariants){
                  return;
              }
      
              if(assignedVariants.split('###').includes(selectedVariant)) {
                  $item.css('order','-1');
              }
          });
      
          $('.lb-product-m-slider__dot').first().trigger('click');
      })
    })
