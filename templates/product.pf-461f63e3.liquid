            $('<li class="slide-min" slide-min-id="v812712"><video style="height:100%;width:100%;" class="no-events" autoplay="" muted="" loop="" playsinline="" webkit-playsinline="">' + $desktopVideo.clone().html() + '</video></li>').insertAfter('[slide-min-id]:nth-child(' + insertVideoAfter + ')');
    
            $('<li style="cursor:auto;" class="slide-max d-none" slide-max-id="v812712"><video style="height:100%;width:100%;" class="no-events" autoplay="" muted="" loop="" playsinline="" webkit-playsinline="">'
                + $desktopVideo.clone().html() + '</video></li>')[insertBeforeAfter]('[slide-max-id]:nth-child(' + insertVideoAfter + ')');
        }
        $('[slide-min-id]').on('mouseenter click', function (e) {
            if (!e) {
                return;
            }
            const { target } = e;
            const $target = $(target);
            const $id = $target.attr('slide-min-id');

            $('.slide-min-active').removeClass('slide-min-active');
            $target.addClass('slide-min-active');

            $('[slide-max-id]').each(function (index, item) {
                const removeOrAddClass = $(item).attr('slide-max-id') == $id ? 'removeClass' : 'addClass';
                $(item)[removeOrAddClass]('d-none');
            })
        });

        $('[slide-max-id]').on('mousemove', function (e) {
            if (!e) {
                return;
            }
            const { currentTarget } = e;
            const currImg = $(currentTarget).find('img');
            currImg.css('transform', "scale(2)");
            currImg.css('transform-origin', `${e.offsetX / e.target.offsetWidth * 100}% ${e.offsetY / e.target.offsetHeight * 100}%`)
        });

        $('[slide-max-id]').on('mouseleave', function (e) {
            if (!e) {
                return;
            }
            const { currentTarget } = e;
            const currImg = $(currentTarget).find('img');
            currImg.removeAttr("style");
        });

        const $minSlideList = $('.lb-product-d-slider__list');
        const icon = document.querySelector('.lb-product-d-slider__icon');
        $minSlideList.on('scroll', function () {
            if (!icon) {
                return;
            }
            const toggleIcon = $minSlideList.scrollTop() + $minSlideList.height() == $minSlideList.prop('scrollHeight') ? 'add' : 'remove';
            icon.classList[toggleIcon]('d-none');
        });
        if ($minSlideList.prop('scrollHeight') > $minSlideList.height()) {
            if (!icon) {
                return;
            }
            icon.classList.remove('d-none');
