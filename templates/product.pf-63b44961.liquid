-chevron-right pfa-arrow" style="width:auto;fill:currentcolor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"></path></svg><span>Produktbeschreibung</span></div></summary><div class="sc-lmEGMn dTrJQN pf-201_ pf-accordion-body" data-pf-expandable="true" data-pf-type="Accordion3.Content"><div class="pf-accordion-display-content"><div data-pf-type="Accordion3.Flex.Content" class="sc-goWbVR iRUUKk pf-202_"><div class="sc-hzhKNl fltMam pf-203_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-204_"><p class="sc-lmUbDS cFVOqs pf-205_ pf-text-1" data-pf-type="Paragraph3">Der AugenRoll-On wurde entwickelt für Männer, die müde Augen nicht akzeptieren.<br> <br>Die kühlende Roll-On-Technologie mit einer Edelstahlkugel sorgt sofort für einen Frische-Kick. Koffein regt die Mikrozirkulation an und mildert Schwellungen sowie Augenringe. Hyaluronsäure polstert die Haut von innen auf und versorgt sie intensiv mit Feuchtigkeit. Der hochwirksame Peptid-Komplex stärkt die Hautstruktur und reduziert feine Linien. <br><br>Das Ergebnis: ein wacher, frischer Blick, der Ausstrahlung und Stärke signalisiert. <br>Perfekt für lange Arbeitstage, nach dem Sport oder wenn die Nacht mal kürzer war. <br>  </p></div></div></div></div></div></div></details><details class="sc-dGVrNp kIZjuh pf-207_" data-pf-type="Accordion3.Content.Wrapper"><summary><div class="sc-deEcaK pLXxN pf-208_ pf-anchor pf-header-item-wrapper" data-header-id="2cc610e5-b5e8-4354-9c91-c73391cd37f3" data-active="false" data-pf-type="Accordion3.Header"><svg class="pf-accordion-icon pfa-chevron-right pfa-arrow" style="width:auto;fill:currentcolor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"></path></svg><span>Anwendung</span></div></summary><div class="sc-lmEGMn dTrJQN pf-210_ pf-accordion-body" data-pf-expandable="true" data-pf-type="Accordion3.Content"><div class="pf-accordion-display-content"><div data-pf-type="Accordion3.Flex.Content" class="sc-goWbVR iRUUKk pf-211_"><div class="sc-hzhKNl fltMam pf-212_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-213_"><p class="sc-lmUbDS cFVOqs pf-214_ pf-text-1" data-pf-type="Paragraph3">Morgens und abends direkt unter den Augen auftragen. Mit dem kühlenden Roll-On sanft über die Haut fahren und kurz einziehen lassen. Kann jederzeit zwischendurch angewendet werden – praktisch für den Alltag oder unterwegs. <br>  </p></div></div></div></div></div></div></details></div></div></div></div></div></div><div data-section-id="pf-82c3" data-pf-type="Section" class="sc-bcSJDS dsCpLi pf-216_ pf-hide"><div style="--cw:1170px" class="sc-enkJyZ gKpywE"><div class="sc-hzhKNl fltMam pf-217_ pf-r pf-r-eh pf-lg-hide" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-218_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-219_ pf-heading-3-h3">Produktbeschreibung</h3><div data-compact="30" data-show-button="true" data-more="Mehr anzeigen" data-less="" data-product-type="content" data-product-id="{{ product.id }}" data-pf-type="ProductDescription" class="sc-euWNFl sc-jsFsvH gruDft izIYwv pf-221_">{{ product.content }}</div></div></div></div><div class="sc-hzhKNl fltMam pf-222_ pf-r pf-r-eh pf-lg-hide" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-223_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-224_ pf-heading-3-h3">Anwendung</h3><p class="sc-iowYbt eEPszQ pf-226_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-34840d23-8025-4a50-8bab-b4f5c77c0456"/><span class="pf-paragraph-content ">Morgens und abends direkt unter den Augen auftragen. Mit dem kühlenden Roll-On sanft über die Haut fahren und kurz einziehen lassen. Kann jederzeit zwischendurch angewendet werden – praktisch für den Alltag oder unterwegs.</span></p></div></div></div><div class="sc-hzhKNl fltMam pf-229_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-230_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-231_ pf-heading-3-h3">FULL ROUTINE</h3></div></div></div><div class="sc-hzhKNl fltMam pf-233_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-234_"><div data-pf-type="Slideshow" class="sc-iXzffn hZoWrg pf-235_"><div data-id="slider-19bbf220-9fbb-40b0-ba9b-1bf666aa2988-all" class="pf-slider scrollfix" style="--ws-xs:60;--ss-xs:1;--ss-sm:2;--ss-md:3;--ss-lg:3"><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-236_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-237_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-238_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-239_"><path d="M160 64c0-11.8-6.5-22.6-16.9-28.2s-23-5-32.8 1.6l-96 64C-.5 111.2-4.4 131 5.4 145.8s29.7 18.7 44.4 8.9L96 123.8V416H32c-17.7 0-32 14.3-32 32s14.3 32 32 32h96 96c17.7 0 32-14.3 32-32s-14.3-32-32-32H160V64z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-240_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-241_">Reinigung</h3></div></div></div><div class="sc-hzhKNl fltMam pf-243_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-244_"><p class="sc-iowYbt eEPszQ pf-245_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-94972f64-b850-4fba-95c1-0037b399baef"/><span class="pf-paragraph-content ">Starte morgens und abends mit der Reinigung. Morgens reicht oft lauwarmes Wasser oder ein mildes Gel, um Schweiß und Talg zu entfernen. Abends gründlich reinigen, um Schmutz, SPF und überschüssiges Öl zu lösen – die Basis, damit alles danach besser wirkt.&nbsp;</span></p></div></div></div></div></div><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-248_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-249_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-250_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-251_"><path d="M142.9 96c-21.5 0-42.2 8.5-57.4 23.8L54.6 150.6c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L40.2 74.5C67.5 47.3 104.4 32 142.9 32C223 32 288 97 288 177.1c0 38.5-15.3 75.4-42.5 102.6L109.3 416H288c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-12.9 0-24.6-7.8-29.6-19.8s-2.2-25.7 6.9-34.9L200.2 234.5c15.2-15.2 23.8-35.9 23.8-57.4c0-44.8-36.3-81.1-81.1-81.1z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-252_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-253_">Toner / Gesichtswasser</h3></div></div></div><div class="sc-hzhKNl fltMam pf-255_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-256_"><p class="sc-iowYbt eEPszQ pf-257_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-b9b17163-83c7-4de6-996a-bd7ea6cca344"/><span class="pf-paragraph-content ">Trage ein alkoholfreies Gesichtswasser auf, um die Haut zu beruhigen, den pH-Wert auszubalancieren und Feuchtigkeit nachzulegen. Mit den Händen einklopfen, nicht reiben. Exfolierende Toner (AHA/BHA) nur abends und 2–3× pro Woche verwenden.</span></p></div></div></div></div></div><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-260_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-261_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-262_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-263_"><path d="M0 64C0 46.3 14.3 32 32 32H272c13.2 0 25 8.1 29.8 20.4s1.5 26.3-8.2 35.2L162.3 208H184c75.1 0 136 60.9 136 136s-60.9 136-136 136H105.4C63 480 24.2 456 5.3 418.1l-1.9-3.8c-7.9-15.8-1.5-35 14.3-42.9s35-1.5 42.9 14.3l1.9 3.8c8.1 16.3 24.8 26.5 42.9 26.5H184c39.8 0 72-32.2 72-72s-32.2-72-72-72H80c-13.2 0-25-8.1-29.8-20.4s-1.5-26.3 8.2-35.2L189.7 96H32C14.3 96 0 81.7 0 64z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-264_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-265_">Serum</h3></div></div></div><div class="sc-hzhKNl fltMam pf-267_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-268_"><p class="sc-iowYbt eEPszQ pf-269_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-a344ab12-3e00-4217-95c0-2981e4c402d9"/><span class="pf-paragraph-content ">Setze auf konzentrierte Wirkstoffe passend zu deinem Ziel: Hyaluron für Feuchtigkeit, Niacinamid für Poren und Glanz, Vitamin C am Morgen für Schutz und Strahlkraft, Retinol abends für glattere Haut. Erst wasserbasierte, dann öligere Seren. Kurz einziehen lassen.</span></p></div></div></div></div></div><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-272_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-273_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-274_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-275_"><path d="M189 77.6c7.5-16 .7-35.1-15.3-42.6s-35.1-.7-42.6 15.3L3 322.4c-4.7 9.9-3.9 21.5 1.9 30.8S21 368 32 368H256v80c0 17.7 14.3 32 32 32s32-14.3 32-32V368h32c17.7 0 32-14.3 32-32s-14.3-32-32-32H320V160c0-17.7-14.3-32-32-32s-32 14.3-32 32V304H82.4L189 77.6z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-276_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-277_">Augenpflege</h3></div></div></div><div class="sc-hzhKNl fltMam pf-279_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-280_"><p class="sc-iowYbt eEPszQ pf-281_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-ca3fcfad-71e1-4edf-b2db-eda50edc90b0"/><span class="pf-paragraph-content ">Eine kleine Menge unter dem Auge entlang des Jochbeins auftupfen oder mit dem Roll-On auftragen. Koffein hilft gegen Schwellungen, Peptide gegen feine Linien, Hyaluron gegen Trockenheit. Sanft einklopfen – nicht ziehen.</span></p></div></div></div></div></div><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-284_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-285_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-286_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-287_"><path d="M32.5 58.3C35.3 43.1 48.5 32 64 32H256c17.7 0 32 14.3 32 32s-14.3 32-32 32H90.7L70.3 208H184c75.1 0 136 60.9 136 136s-60.9 136-136 136H100.5c-39.4 0-75.4-22.3-93-57.5l-4.1-8.2c-7.9-15.8-1.5-35 14.3-42.9s35-1.5 42.9 14.3l4.1 8.2c6.8 13.6 20.6 22.1 35.8 22.1H184c39.8 0 72-32.2 72-72s-32.2-72-72-72H32c-9.5 0-18.5-4.2-24.6-11.5s-8.6-16.9-6.9-26.2l32-176z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-288_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-289_">Creme / Moisturizer</h3></div></div></div><div class="sc-hzhKNl fltMam pf-291_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-292_"><p class="sc-iowYbt eEPszQ pf-293_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-0edc90b0-48aa-4e2c-b1fb-8dd8487f1759"/><span class="pf-paragraph-content ">Fixiere die Feuchtigkeit und stärke die Barriere. Tagsüber eine leichte, schnell einziehende Textur; abends eine reichhaltigere Pflege, wenn die Haut mehr braucht. Gleichmäßig auf Gesicht und Hals verteilen.</span></p></div></div></div></div></div><div class="pf-slide"><div class="sc-bJUkdm fydhRR pf-296_" data-pf-type="SlideshowSlide"><div class="sc-hzhKNl fltMam pf-297_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:3;--c-md:3;--c-lg:3"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-298_"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-299_"><path d="M232.4 84.7c11.4-13.5 9.7-33.7-3.8-45.1s-33.7-9.7-45.1 3.8L38.6 214.7C14.7 242.9 1.1 278.4 .1 315.2c0 1.4-.1 2.9-.1 4.3c0 .2 0 .3 0 .5c0 88.4 71.6 160 160 160s160-71.6 160-160c0-85.5-67.1-155.4-151.5-159.8l63.9-75.6zM256 320A96 96 0 1 1 64 320a96 96 0 1 1 192 0z"></path></svg></div></div><div class="pf-c" style="--c-xs:12;--c-sm:9;--c-md:9;--c-lg:9"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-300_"><h3 data-pf-type="Heading2" class="sc-cTTcKX ejfvWQ pf-301_">Sonnenschutz (SPF)</h3></div></div></div><div class="sc-hzhKNl fltMam pf-303_ pf-r pf-r-eh" style="--s-xs:15px;position:relative" data-pf-type="Row"><div class="pf-c" style="--c-xs:12;--c-sm:12;--c-md:12;--c-lg:12"><div data-pf-type="Column" class="sc-dOorzJ liFmcT pf-304_"><p class="sc-iowYbt eEPszQ pf-305_" data-pf-type="Paragraph4"><input type="checkbox" id="compact-ff5c5b77-b23f-45fa-9e44-6091cbf728ca"/><span class="pf-paragraph-content ">Morgens als letzten Schritt: Breitband-SPF 30–50 großzügig auf Gesicht, Ohren und Hals auftragen. Bei längerer UV-Exposition alle zwei Stunden nachlegen. Ohne konsequenten SPF verliert jede Routine an Wirkung.</span></p></div></div></div></div></div><button type="button" style="visibility:hidden" aria-label="Previous" class="pf-slider-prev nav-style-1 "></button><button type="button" style="visibility:hidden" aria-label="Next" class="pf-slider-next nav-style-1 "></button></div></div></div></div></div></div></div><div data-section-id="pf-265e" data-pf-type="Section" class="sc-bcSJDS dsCpLi pf-308_ pf-lg-hide pf-md-hide pf-sm-hide"><div style="--cw:1170px" class="sc-enkJyZ gKpywE"><div class="sc-hzhKNl fltMam pf-309_ pf-r pf-r-eh pf-hide" style="--s-xs:15px;position:relative" data-pf-type="Row"><div cla