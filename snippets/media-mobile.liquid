<script>
  document.addEventListener("DOMContentLoaded", () => {

    document.addEventListener("variant:change", async (e) => {

      if(window.innerWidth >= 768) return;

      console.log("variant:change")
      const variantID = e.detail.variant.id;
      try {
        const sectionUrl = `/products/{{ product.handle }}?variant=${variantID}&section_id=media-mobile`;

        const response = await fetch(sectionUrl);
        const html = await response.text();

        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const updatedSection = doc.getElementById('shopify-section-media-mobile').querySelector("#image-gallery-mobile").innerHTML;

        document.getElementById("image-gallery-mobile").innerHTML = updatedSection

        handleProductMedia(e.detail.variant.id)
      } catch (error) {
        console.error("Error loading preorder section:", error);
      }
    })
  })
</script>

<!-- Swiper JS -->
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

<!-- Initialize Swiper -->
<script defer>
  document.addEventListener("DOMContentLoaded", () => {
    var swiper = new Swiper(".mySwiper", {
      pagination: {
        el: ".swiper-pagination",
      },
    });
  });
  window.addEventListener("load", () => {
    var swiper = new Swiper(".mySwiper", {
      pagination: {
        el: ".swiper-pagination",
      },
    });
  })
</script>
