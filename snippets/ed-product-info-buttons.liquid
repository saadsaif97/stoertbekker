{% assign index = index | minus: 1 %}
{% if product.metafields.ed_sb.product_benefits_on_images.value[index].title != blank %}
    <div class="product-info-button-container ed-ab-sb-8" style="background: {{ settings.benefits_on_images_color }}">
        <div class="inner">
            <div class="info-title">{{ product.metafields.ed_sb.product_benefits_on_images.value[index].title }}</div>
        </div>
        {% if product.metafields.ed_sb.product_benefits_on_images.value[index].text != blank %}
            <div class="info-icon">
                <span class="more-info-icon">Mehr Infos</span>
                <span class='info-icon-svg'>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18">
                    <g id="Gruppe_1" data-name="Gruppe 1" transform="translate(-505 -424)">
                      <path id="icons8-info" d="M11,2a9,9,0,0,0,0,18,9.137,9.137,0,0,0,6.967-3.306A8.76,8.76,0,0,0,20,11,9.006,9.006,0,0,0,11,2Zm0,.783A8.217,8.217,0,1,1,2.783,11,8.211,8.211,0,0,1,11,2.783Zm0,2.739A1.174,1.174,0,1,0,12.174,6.7,1.174,1.174,0,0,0,11,5.522ZM9.435,9.435v.783h.783V15.3H9.435v.783h3.13V15.3h-.783V9.435H9.435Z" transform="translate(503 422)" fill="#fff"/>
                      <g id="Ellipse_1" data-name="Ellipse 1" transform="translate(505 424)" fill="none" stroke="#fff" stroke-width="1.5">
                        <circle cx="9" cy="9" r="9" stroke="none"/>
                        <circle cx="9" cy="9" r="8.25" fill="none"/>
                      </g>
                    </g>
                  </svg>
                </span>
            </div>
            <div class="info-content-container">
                <div class="inner">
                    <span>{{ product.metafields.ed_sb.product_benefits_on_images.value[index].text }}</span>
                </div>
            </div>
        {% endif %}
    </div>
{% endif %}
