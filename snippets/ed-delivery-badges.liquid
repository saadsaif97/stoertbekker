<script>
   if(Shopify.Checkout.step == "shipping_method"){
       
        const edSmallBadge = document.createElement("span");
        edSmallBadge.className = 'ed-delivery-badge-container';
        edSmallBadge.innerHTML = "<img src='https://cdn.shopify.com/s/files/1/0317/7116/4804/files/dhl-gogreen.svg?v=1679582570' alt='dhl'>";

        const edBigBadge = document.createElement("span");
