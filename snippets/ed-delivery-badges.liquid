        edBigBadge.innerHTML = "<img src='https://cdn.shopify.com/s/files/1/0317/7116/4804/files/dhl-gogreen.svg?v=1679582570' alt='dhl'>";

     <!-- ERSTE ZEILE -->
     let edStandardDelivery = document.querySelector('.radio__label__primary[data-shipping-method-label-title="DHL - Standard"]'); 
     if (edStandardDelivery) {
         edStandardDelivery.innerText = 'DHL Paket (Klimaneutral)'
         edStandardDelivery.appendChild(edSmallBadge);
     }
     

     <!-- ZWEITE ZEILE --> 
