<div class="lb-bundle-builder-flyout-container">
	<div class="lb-bundle-builder-flyout-container-header">
		Wähle Dein Produkt 
	    <div class="lb-bundle-builder-flyout-container-closer">X</div>
	</div>
 


 <div class="lb-bundle-builder-item-holder-1">
		{% for product in collections.shampoo-bars.products %}
      {% if product.variants.size < 1 %}
        <div id="droppo1{{ product.id }}" class="droppo">
        	<div id="lb-bb-select-item-1-{{ product.id }}" onclick="bbfso1{{product.id}}()" class="lb-bundle-builder-flyout-select-item-dropwdown">
        		<img src="{{ product.featured_image | img_url: '50x' }}">
                <div>
            		<p>{{ product.title }}</p> 
                </div>
			</div> 
  			
            {% for variant in product.variants %} 		
    			<div {% if variant.available %}onclick="bbfs1{{variant.id}}()"{%else%}style="opacity: 0.5;"{%endif%} class="lb-bundle-builder-flyout-select-item lb-bundle-builder-flyout-select-subitem {% if variant.available %}lb-bundle-builder-flyout-select-item-available{%endif%}">
      				<img src="{{variant.image.src | img_url: '50x'}}">
                    <p>{{ product.title }} <span>Variante: {{ variant.title }}</span></p>
                    {% if variant.available %}{%else%}<div class="lb-bundle-builder-flyout-select-item-outofstock-call">Ausverkauft</div>{%endif%}
  				</div> 	  
			{%endfor%}
    	  </div>
    	{%else%}
            {% if product.available %}
        		<div onclick="bbf1{{product.id}}()" id="lb-bb-select-item-1-{{ product.id }}" class="lb-bundle-builder-flyout-select-item lb-bundle-builder-flyout-select-item-available">
    				<img src="{{ product.featured_image | img_url: 'thumb' }}">
					<div>
    					<p>{{ product.title }}</p> 
                    </div>
  				</div> 
            {%else%}
    		  	<div id="lb-bb-select-item-1-{{ product.id }}" class="lb-bundle-builder-flyout-select-item-outofstock">
    				<img src="{{ product.featured_image | img_url: 'thumb' }}">
					<p>{{ product.title }}<span>Ausverkauft</span></p>
  				</div> 		
  			{%endif%}
	   {%endif%}   
      
	  <!-- Script für einzelne Produkte -->
		<script>
		function bbf1{{product.id}}() {
			document.getElementById('bundbuilder1valimg').src = "{{ product.featured_image | img_url: 'thumb' }}";
			document.getElementById('bundbuilder1val').value = "{{product.selected_or_first_available_variant.id}}";
			document.getElementById('bundlebuilder1name').innerHTML= "{{product.title}}";
		}
		</script>

	  	<!-- Script für varianten opener -->
		<script>
		function bbfso1{{product.id}}() {
			var element = document.getElementById("droppo1{{ product.id }}");
			element.classList.toggle("lb-bundle-builder-flyout-select-item-dropwdown-show");
		}
		</script>

	  	<!-- Script für mehrere Varianten -->
		{% for variant in product.variants %}
		<script>
		function bbfs1{{variant.id}}() {
			document.getElementById('bundbuilder1valimg').src = "{{variant.image.src | img_url: 'thumb'}}";
			document.getElementById('bundbuilder1val').value = "{{variant.id}}";
			document.getElementById('bundlebuilder1name').innerHTML= "{{product.title}} |&nbsp;{{variant.title}}";
		}
		</script>
		{%endfor%}    

		{% endfor %}
	</div> 
  
  
  
  
  
  
  
  
