<script>
window.addEventListener('load',() =&gt; {
	$('.js-addBundleProducts').on('click', (e) =&gt; {
		e.preventDefault();
		$.ajax({
			type: "POST",
			url: '/cart/add.js',
			data: {
				items: Object.values([...document.querySelectorAll('.js-bundleProductId')].reduce((acc, item) =&gt; {
					const id = item.value;
					if (acc[id]) {
						if (acc[id].quantity) {
							acc[id].quantity += 1
						} else {
							acc[id].quantity = 1
						}
					} else {
						acc[id] = {}
						acc[id].quantity = 1
						acc[id].id = id
					}

					return acc
				}, {}))
			},
			success: (resp) =&gt; {
				if($(e.currentTarget).hasClass('js-cartUpdate')) {
					window._updateCart()
				}
			},
			dataType: 'JSON'
		});
	})
  })
</script>



