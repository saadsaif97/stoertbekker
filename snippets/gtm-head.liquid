<script>
    window.dataLayer = window.dataLayer || [];
      !function() {
          {% if customer %}
              var object = {
                  "visitorType": "Logged In",
                  "visitorId": "{{ customer.id | remove: "'" }}",
                  "CustomerId": "{{ customer.id | remove: "'" }}",
                  "CustomerOrdersCount": "{{ customer.orders_count }}",
                  "CustomerTotalSpent": "{{ customer.total_spent | divided_by: 100 }}",
              };
        
              {% if customer.id %}
                  object['CustomerId'] = "{{ customer.id }}",
                  object['sha_customerId'] = "{{ customer.id | strip | downcase | sha256}}",
              {% endif %}
            
              {% if customer.first_name %}
                  object['CustomerFirstName'] = "{{ customer.first_name }}",
                  object['sha_fn'] = "{{ customer.first_name | strip | downcase | sha256}}",
              {% endif %}
              
              {% if customer.last_name %}
                  object['CustomerLastName'] = "{{ customer.last_name }}",
                  object['sha_ln'] = "{{ customer.last_name | strip | downcase | sha256}}",
              {% endif %}
              
              {% if customer.email %}
                  object['CustomerEmail'] = "{{ customer.email }}",
                  object['sha_email'] = "{{ customer.email | strip | sha256}}",
              {% endif %}
              
              {% if customer.default_address.phone %}
                  object['CustomerPhone'] = "{{ customer.default_address.phone }}",
                  object['sha_ph'] = "{{ customer.default_address.phone | strip | remove: "+" | sha256}}",
              {% endif %}
              
              {% if customer.default_address.city %}
                  object['CustomerCity'] = "{{ customer.default_address.city }}",
                  object['sha_ct'] = "{{ customer.default_address.city | strip | downcase | sha256}}",
              {% endif %}
              
              {% if customer.default_address.zip %}
                  object['CustomerZip'] = "{{ customer.default_address.zip }}",
                  object['sha_zp'] = "{{ customer.default_address.zip | strip | downcase | sha256}}",
              {% endif %}
              
              {% if customer.default_address.country_code %}
                  object['CustomerCountryCode'] = "{{ customer.default_address.country_code }}",
                  object['sha_country'] = "{{ customer.default_address.country_code | strip | downcase | sha256}}",
              {% endif %}
              
              window.dataLayer.push(object);
  
          {% else %}
              window.dataLayer.push({
                  "visitorType": "Guest",
              });
          {% endif %}
      }(0)
    //Event ID Generator
    window.temp_track_store = window.temp_track_store || {};
    window.temp_track_store.event_id = window.temp_track_store.event_id || {};
    window.temp_track_store.generateEventId = function (event) {
      var length = 15
      var result = "";
      var characters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
      var charactersLength = characters.length;
      for ( var i = 0; i < length; i++ ) {
        result += characters.charAt(Math.floor(Math.random() * charactersLength));
      }
      return event+"_"+result+"_"+new Date().getTime();
    }
  
    var generateEventId = window.temp_track_store.generateEventId;
  
    //Page View
    window.temp_track_store.event_id["gtm.js"] = generateEventId("gtm.js");
    //Dom Ready
    window.temp_track_store.event_id["gtm.dom"] = generateEventId("gtm.dom");
    //Window Loaded
    window.temp_track_store.event_id["gtm.load"] = generateEventId("gtm.load");

    //Login Event
    {% if customer %}
        var _login = sessionStorage.getItem('login_event');
        var event_id = generateEventId('login');
        window.temp_track_store.event_id['login'] = event_id;
        if (_login != "false") {
            window.dataLayer.push({
                event: 'login',
                event_id: event_id,
            })
        }
        sessionStorage.setItem('login_event',false);
    {% else %}
        if (sessionStorage.getItem('login_event') !== null) sessionStorage.removeItem('login_event');
    {% endif %}
  </script>

