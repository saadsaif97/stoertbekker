

{% comment %} abscale ST-0015 START 
{% if canonical_url contains '/products/' %}
<script>
  if (window.innerWidth <= 768) {
  
document.addEventListener("DOMContentLoaded", function () {
  try {
  
  
  const variants = document.querySelectorAll(".sc-dtDOqo.lfZCLK.pf-43_");
  const safe_info = document.querySelectorAll(".sc-dtDOqo.lfZCLK.pf-65_");
  const button_text = document.querySelector(".lb-new-send");
  const price = document.querySelector('[data-product-type="price"]');
  let old_content = "";

  if (variants.length && safe_info.length) {
      variants.forEach((variant) => {
          variant.classList.add("as-st-0015-varaints");
      });

      safe_info.forEach((info) => {
          info.classList.add("as-st-0015-safe-info");
          info.parentNode.insertBefore(info, variants[0].nextSibling);
      });
  }

  if (button_text && price) {
      const btn_div = document.createElement("div");
      const parent_btn = button_text.parentNode;

      const price_text = price.textContent;
      old_content = button_text.innerHTML;
      button_text.innerHTML = old_content;

      btn_div.classList.add("as-st-0015-button");
      button_text.classList.add("as-st-0015-button-text");

      btn_div.appendChild(button_text);
      parent_btn.parentNode.insertBefore(btn_div, parent_btn.nextSibling);
  }

  /**
   * Waits for the specified element(s) to be present in the DOM and then executes a callback function.
   *
   * @param {string} selector - The CSS selector for the element(s) to wait for.
   * @param {Function} callback - The callback function to execute when the element(s) are found.
   * @param {boolean} [waitOnce=false] - Optional. Specifies whether to wait for the element(s) only once. Default is false.
   */
  function tsDev_waitForElement(selector, callback, waitOnce = false) {
      if (typeof selector !== "string") {
          console.error("1. Argument: selector must be a string.");
          return;
      }
  
      if (typeof callback !== "function") {
          console.error("2. Argument: callback must be a function.");
          return;
      }
  
      if (typeof waitOnce !== "boolean") {
          console.error("3. Argument: waitOnce must be a boolean.");
          return;
      }
  
      const observedElements = new Set();
  
      const queryMethodType = waitOnce ? "querySelector" : "querySelectorAll";
  
      const handleMutations = (mutationsList, observer) => {
          const elements = waitOnce
              ? [document[queryMethodType](selector)]
              : document[queryMethodType](selector);
          elements.forEach((element) => {
              if (element && !observedElements.has(element)) {
                  observedElements.add(element);
                  callback(element);
                  if (waitOnce) {
                      observer.disconnect();
                      return;
                  }
              }
          });
      };
  
      const elements = waitOnce
          ? [document[queryMethodType](selector)]
          : document[queryMethodType](selector);
      elements.forEach((element) => {
          if (element && !observedElements.has(element)) {
              observedElements.add(element);
              callback(element);
              if (waitOnce) {
                  return;
              }
          }
      });
  
      const observer = new MutationObserver(handleMutations);
      observer.observe(document.documentElement, {
          childList: true,
          subtree: true,
          attributes: false,
      });
  }
  
  tsDev_waitForElement(".needsclick.kl-teaser-TLexcU", (element) => {
      console.log("Multiple Element Check:", element);
      const save = document.querySelector(".needsclick.kl-teaser-TLexcU");
          if (save) {
              save.classList.add("as-st-0015-save");
          }
  });

  const target = document.querySelector(
      "[data-pf-type='ProductPrice'][data-product-type='price']"
  );

  const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
          as_st_0015_updatePrice();
      });
  });
  observer.observe(target, {
      attributes: true,
      childList: true,
      subtree: true,
      characterData: true,
  });

function as_st_0015_updatePrice() {
    const prices = document.querySelectorAll(
        ".lb-pricing-new [data-pf-type='ProductPrice']"
    );
    const price =
        prices[prices.length - 1] ||
        document.querySelector("[data-pf-type='ProductPrice']");
    if (price && button_text) {
        // Ignoriere den Preis
        const price_text = ""; // Überspringe die Preis-Verwendung
        button_text.innerHTML = old_content; // Zeige nur den alten Inhalt
    }
}

    
} catch (error) {
  console.error("Error in ST-0015:", error);
}
});
}
</script>

