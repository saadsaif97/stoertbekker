{%- assign current_variant = product.selected_or_first_available_variant -%}

<div id="second-cart">
    <div class="second-cart-holder">
		{% for image in product.images limit: 1 %} 
			<img class="second-cart-img" id="{{ img_id }}" src="{{ image | img_url: '100x' }}" loading="lazy">
		{% endfor %}
		<div class="second-cart-info">
        	<h2>{{ product.title }}</h2>


        
{% if product.variants.size > 1 %}
            <p class="lb-second-cart-bar-varian-title" style="font-size: 12px; color: grey;">{{ product.selected_or_first_available_variant.title }}</p>
{% endif %}
  
          <a href="#ReviewsWidget"><div class="ruk_rating_snippet" data-sku="{{ product.handle }};{{ product.variants | map: 'sku' | join: ';' }};{{ product.variants | map: 'id' | join: ';' }}"></div></a>      
			
  <!--
          <div class="price-color lb-second-cart-bar-price" style="float: left; margin-right: 9px; line-height:28px; font-size: 16px;color: black;"><span style="color: #DA2C2C; font-size: 16px;text-decoration: line-through;">{{ current_variant.compare_at_price | money }}</span> {{ product.selected_or_first_available_variant.price | money }}</div>
        -->
        
        </div>  


          
        <a href="#buy" class="lb-buy-btn lb-second-cart-bar-old-cta" id="lb-buy-btn">{% if canonical_url contains '.com/en' %}BACK TO PRODCUT{% else %}ZUM PRODUKT{% endif %}</a>
      
<div class="lb-second-cart-bar-direct-cta">

  	<form action="/cart/add" method="post" enctype="multipart/form-data" id="add-to-cart-{{ product.handle }}">
          <input type="text" name="id" value="{{ product.selected_or_first_available_variant.id }}" hidden>
          <button class="lb-buy-btn lb-cart-drawer-opener" type="submit" name="add" data-add-to-cart>IN DEN WARENKORB</button>
		</form>
</div>      


      
    </div>
</div>





